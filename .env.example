# ============================================================
# Aradune Environment Variables
# Copy this file to .env and fill in the values.
# Never commit .env files with real credentials to git.
# ============================================================

# ── Frontend (Vite) ──────────────────────────────────────────
# These must be prefixed with VITE_ to be accessible in the browser.

# FastAPI backend URL (Fly.io in production, empty string for local dev proxy)
VITE_API_URL=https://aradune-api.fly.dev

# External URL for the 82MB claims_monthly.parquet file (too large for Vercel)
VITE_MONTHLY_PARQUET_URL=

# Clerk authentication — when set, replaces the password gate with Clerk sign-in
# Get from https://dashboard.clerk.com → your app → API Keys
VITE_CLERK_PUBLISHABLE_KEY=pk_test_...

# ── Backend (FastAPI / server/) ──────────────────────────────
# These are read by server/config.py with the ARADUNE_ prefix.

# Path to the Parquet data lake directory
ARADUNE_LAKE_DIR=data/lake

# CORS origins allowed to call the API (JSON array)
ARADUNE_CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]

# Maximum rows returned by query endpoints
ARADUNE_MAX_ROWS=10000

# Port for the uvicorn server
ARADUNE_PORT=8000

# ── AI / Claude ──────────────────────────────────────────────
# Used by NL2SQL (server/routes/nl2sql.py), Intelligence endpoint
# (server/routes/intelligence.py), and Policy Analyst (api/chat.js)
ANTHROPIC_API_KEY=sk-ant-...

# ── Clerk Authentication (server-side JWT verification) ─────
# Required for protecting Intelligence/PolicyAnalyst endpoints
# When not set, auth middleware is bypassed (password gate fallback)
CLERK_SECRET_KEY=sk_test_...

# Optional: Clerk issuer URL (auto-detected from secret key if not set)
# CLERK_ISSUER=https://clerk.your-domain.com

# ── Stripe Billing (future — Track B monetization) ──────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PRICE_ID_INDIVIDUAL=price_...
STRIPE_PRICE_ID_ORG=price_...

# ── Policy Analyst Auth Tokens ───────────────────────────────
# Master admin key for Policy Analyst
ADMIN_KEY=

# Preview token for password-gated access (defaults to "mediquiad")
PREVIEW_TOKEN=mediquiad

# Comma-separated static analyst tokens (legacy)
ANALYST_TOKENS=

# ── R2 / S3 (Cloudflare R2 for Parquet lake storage) ────────
# Used by scripts/sync_lake.py and server/entrypoint.sh

# R2 bucket name
ARADUNE_S3_BUCKET=aradune-datalake

# Key prefix inside the bucket
ARADUNE_S3_PREFIX=lake/

# Cloudflare R2 S3-compatible endpoint
ARADUNE_S3_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com

# R2 access credentials (S3-compatible)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# ── Dagster Pipeline (optional) ──────────────────────────────
# Webhook URL for pipeline failure/success alerts (e.g. Slack)
ARADUNE_ALERT_WEBHOOK=

# ── Vercel (CI/CD only — set as GitHub secrets, not here) ───
# VERCEL_TOKEN=
# VERCEL_ORG_ID=
# VERCEL_PROJECT_ID=

# ── Fly.io (CI/CD only — set as GitHub secrets, not here) ───
# FLY_API_TOKEN=
